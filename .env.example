# Taffy 直播助手 — 环境变量配置
# 复制此文件为 .env 并根据实际情况修改
# 使用前: source .env

# ---- JWT 认证 ----
JWT_SECRET=taffy-live-assistant-jwt-secret-key-2026
JWT_EXPIRATION=86400000

# ---- 数据库 ----
SPRING_DATASOURCE_URL=jdbc:sqlite:./data/taffy.db

# ---- 音频存储 ----
VOICE_AI_STORAGE_ROOT=./data/audio

# ---- 阿里云 TTS（可选，不配置则使用本地 espeak-ng）----
ALIYUN_TTS_ENABLED=true
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_APP_KEY=NMATtWj5P8ymqvPj
ALIYUN_TTS_ENDPOINT=https://nls-gateway.cn-shanghai.aliyuncs.com
ALIYUN_TTS_VOICE_NAME=xiaoyun
ALIYUN_TTS_SAMPLE_RATE=16000
ALIYUN_TTS_FORMAT=wav

# ---- JVM 参数 ----
JAVA_OPTS=-Xms128m -Xmx512m
